# ── LLM (optional — stub mode works without these) ──
OPENAI_API_KEY=
OPENAI_BASE_URL=
LMQ_LLM_MODEL=gpt-4o-mini

# ── AWS Cloud (optional — local-first by default) ──
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_SECRET_NAME=
MLFLOW_TRACKING_URI=

# ── AWS Identity (for local dev against AWS resources) ──
# Uses the default boto3 credential chain: env vars, ~/.aws/credentials,
# IAM role, SSO profile, etc.  Set these only if not using a profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
